<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UDP_Basic_Protocol.MainPage"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
            <Border HeightRequest="250">
                <VerticalStackLayout>
                    <Label Text="Wiadomości" HorizontalOptions="Center"/>
                    <CollectionView x:Name="MessagesLayout" SelectionMode="Single" SelectionChanged="MessagesLayout_SelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding DisplayText}" FontSize="14" TextColor="Black"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
            <Entry Placeholder="Receiver IP:HOST" x:Name="Iphost"/>
            <Entry Placeholder="Username" x:Name="Username"/>
            <Entry Placeholder="Message" x:Name="WritedMessage"/>
            <Button Text="Send" Clicked="Button_Clicked"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
